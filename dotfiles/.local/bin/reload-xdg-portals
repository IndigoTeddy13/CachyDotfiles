#!/usr/bin/env bash
sleep 1
# Grab necessary environment variables
# dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
# Kill existing portal services
systemctl --user stop xdg-desktop-portal xdg-desktop-portal-hyprland xdg-desktop-portal-wlr xdg-desktop-portal-gnome xdg-desktop-portal-kde xdg-desktop-portal-gtk 2>/dev/null
# Restart portal services
if pgrep -x "gnome-shell" >/dev/null; then
    /usr/lib/xdg-desktop-portal-gnome &
    /usr/lib/xdg-desktop-portal-gtk &
elif pgrep -x "kwin_wayland" >/dev/null; then
    /usr/lib/xdg-desktop-portal-kde &
elif pgrep -x "Hyprland" >/dev/null; then
    /usr/lib/xdg-desktop-portal-hyprland &
    /usr/lib/xdg-desktop-portal-gtk &
elif pgrep -x "mango" >/dev/null; then
    /usr/lib/xdg-desktop-portal-wlr &
    /usr/lib/xdg-desktop-portal-gtk &
fi
/usr/lib/xdg-desktop-portal &
