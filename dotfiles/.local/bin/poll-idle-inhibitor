#!/usr/bin/env bash

# Check for active audio output (playback)
if pactl list sink-inputs | grep -q "Corked: no"; then
    OUTPUT_ACTIVE=true
else
    OUTPUT_ACTIVE=false
fi

# Check for active audio input (microphone/recording)
if pactl list source-outputs | grep -q "Corked: no"; then
    INPUT_ACTIVE=true
else
    INPUT_ACTIVE=false
fi


# Determine the state and output the correct JSON for Waybar
if [ "$OUTPUT_ACTIVE" = true ] && [ "$INPUT_ACTIVE" = true ]; then
    echo '{"text":"  ", "alt":"output-input", "class":"output-input"}'
elif [ "$OUTPUT_ACTIVE" = true ]; then
    echo '{"text":"", "alt":"output", "class":"output"}'
elif [ "$INPUT_ACTIVE" = true ]; then
    echo '{"text":"", "alt":"input", "class":"input"}'
else
    echo '{"text":"󰟶", "alt":"none", "class":"none"}'
fi